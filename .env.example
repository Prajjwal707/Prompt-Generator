# PromptGenius Backend Environment Configuration
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=5000

# Logging Configuration
LOG_LEVEL=INFO

# Model Configuration
MODEL_DIR=models
MODEL_NAME=llama-2-7b-chat.Q4_K_M.gguf
N_CTX=2048
N_THREADS=4
N_GPU_LAYERS=0
VERBOSE=False

# Inference Parameters
TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=300
REPEAT_PENALTY=1.1

# API Keys (comma-separated for multiple keys)
API_KEYS=your_api_key_here,another_api_key_here

# Rate Limiting
RATE_LIMIT_PER_HOUR=100

# Security
SECRET_KEY=your_secret_key_here
CORS_ORIGINS=*

# Database (if needed in future)
DATABASE_URL=sqlite:///promptgenius.db

# Monitoring
ENABLE_MONITORING=True
MONITOR_LOG_RETENTION_DAYS=30

# Fine-tuning Configuration
FINETUNE_OUTPUT_DIR=finetune/checkpoints
FINETUNE_BATCH_SIZE=4
FINETUNE_LEARNING_RATE=2.0e-4
FINETUNE_EPOCHS=3

# Hardware Configuration
DEVICE=auto
MIXED_PRECISION=fp16
GRADIENT_CHECKPOINTING=True

# External Services (optional)
WANDB_API_KEY=your_wandb_key_here
HUGGINGFACE_TOKEN=your_hf_token_here
